{
  "name": "smart-hoop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:cap": "cross-env CAPACITOR=true vite build",
    "preview": "vite preview",
    "cap:sync": "npm run build:cap && npx cap sync android",
    "cap:open": "npx cap open android",
    "generate:android-assets": "node scripts/prepare-android-assets.js && capacitor-assets generate --android --iconBackgroundColor \"#1a1a2e\" --splashBackgroundColor \"#1a1a2e\""
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.4.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "cross-env": "^10.1.0",
    "vite": "^6.2.0",
    "vite-plugin-pwa": "^0.21.1",
    "vite-plugin-vue-devtools": "^8.1.5"
  }
}
